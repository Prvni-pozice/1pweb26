---
// Menu se strukturou webu — trigger "Menu" (jako starý web), overlay s plnou strukturou.
import site from '../data/site.json';
const map = site as Record<string, any>;
const SECTIONS = [
  { path: '/weby/', label: 'Weby' },
  { path: '/eshopy/', label: 'E-shopy' },
  { path: '/marketing/', label: 'SEO a marketing' },
  { path: '/blog/', label: 'Blog' },
];
const EXTRA = [
  { path: '/ai-agenti/', label: 'AI & agenti' },
  { path: '/skoleni/', label: 'AI školení' },
  { path: '/o-nas/', label: 'O nás' },
  { path: '/kontakt/', label: 'Kontakt' },
];
function kids(path: string) {
  const n = map[path];
  return n ? (n.children || []).map((c: string) => map[c]).filter(Boolean) : [];
}
const tree = SECTIONS.map((s) => ({ ...s, children: kids(s.path) }));
---
<button class="menu-trigger" type="button" aria-label="Otevřít menu" aria-expanded="false" aria-controls="site-menu" data-ham-open>
  <span class="mt-icon"><span></span><span></span><span></span></span>
  <span class="mt-label">Menu</span>
</button>

<div class="ham-overlay" id="site-menu" data-ham-overlay>
  <div class="ham-inner">
    <div class="ham-head">
      <span class="overline"><span class="dot"></span><span class="label">Navigace</span></span>
      <button class="ham-close" type="button" data-ham-close aria-label="Zavřít menu"><span class="x">✕</span><span class="xlabel">zavřít</span></button>
    </div>
    <nav class="ham-nav" aria-label="Hlavní navigace">
      <div class="ham-cols">
        {tree.map((s) => (
          <div class="ham-col">
            <a href={s.path} class="ham-sec">{s.label}</a>
            {s.children.length > 0 && (
              <ul>
                {s.children.slice(0, 10).map((c: any) => <li><a href={c.path}>{c.label}</a></li>)}
                {s.children.length > 10 && <li><a href={s.path} class="more">+ vše ({s.children.length}) →</a></li>}
              </ul>
            )}
          </div>
        ))}
      </div>
      <div class="ham-extra">
        {EXTRA.map((e) => <a href={e.path}>{e.label}</a>)}
      </div>
    </nav>
  </div>
</div>

<style>
  .menu-trigger {
    display: inline-flex; align-items: center; gap: 9px; padding: 9px 16px;
    background: var(--n-900); color: #fff; border: 0; border-radius: var(--radius-pill);
    font-family: var(--font-sans); font-size: 15px; font-weight: var(--fw-medium); cursor: pointer;
    transition: background var(--dur-base) var(--ease-standard);
  }
  .menu-trigger:hover { background: var(--n-800); }
  .menu-trigger:focus-visible { outline: none; box-shadow: var(--ring); }
  .mt-icon { display: inline-flex; flex-direction: column; gap: 3.5px; width: 16px; }
  .mt-icon span { height: 2px; background: var(--lime); border-radius: 2px; }
  .mt-label { line-height: 1; }

  .ham-overlay { display: none; position: fixed; inset: 0; z-index: 300; background: rgba(247,248,245,.98); backdrop-filter: var(--blur-glass); -webkit-backdrop-filter: var(--blur-glass); overflow-y: auto; }
  .ham-overlay.is-open { display: block; }
  .ham-inner { max-width: var(--container-wide); margin: 0 auto; padding: 22px clamp(20px,5vw,64px) 64px; }
  .ham-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 36px; }
  .ham-close { display: inline-flex; align-items: center; gap: 7px; background: transparent; border: 1px solid var(--border-strong); border-radius: var(--radius-pill); padding: 8px 14px; cursor: pointer; color: var(--text-strong); }
  .ham-close:hover { border-color: var(--n-400); }
  .ham-close .x { font-size: 18px; line-height: 1; }
  .ham-close .xlabel { font-family: var(--font-mono); font-size: 11px; letter-spacing: .08em; text-transform: uppercase; color: var(--text-muted); }
  .ham-cols { display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; }
  .ham-sec { display: block; font-size: 22px; font-weight: var(--fw-black); letter-spacing: -.018em; color: var(--text-strong); padding-bottom: 12px; margin-bottom: 12px; border-bottom: 2px solid var(--lime); }
  .ham-sec:hover { color: var(--lime-800); }
  .ham-col ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 9px; }
  .ham-col li a { font-size: 15px; color: var(--text-muted); }
  .ham-col li a:hover { color: var(--lime-800); }
  .ham-col .more { font-family: var(--font-mono); font-size: 12px; color: var(--accent-ink); }
  .ham-extra { margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--border); display: flex; flex-wrap: wrap; gap: 24px; }
  .ham-extra a { font-size: 16px; font-weight: var(--fw-medium); color: var(--text); }
  .ham-extra a:hover { color: var(--lime-800); }

  @media (max-width: 880px) { .ham-cols { grid-template-columns: 1fr 1fr; gap: 24px; } }
  @media (max-width: 560px) { .ham-cols { grid-template-columns: 1fr; } .mt-label { display: none; } .menu-trigger { padding: 10px 12px; } }
</style>

<script>
  // Modulový script je deferovaný → DOM je hotový, voláme přímo. Třídový přepínač (.is-open).
  function initSiteMenu() {
    const trigger = document.querySelector('[data-ham-open]');
    const overlay = document.querySelector('[data-ham-overlay]');
    if (!trigger || !overlay) return;
    const open = () => { overlay.classList.add('is-open'); trigger.setAttribute('aria-expanded', 'true'); document.body.style.overflow = 'hidden'; };
    const close = () => { overlay.classList.remove('is-open'); trigger.setAttribute('aria-expanded', 'false'); document.body.style.overflow = ''; };
    trigger.addEventListener('click', open);
    overlay.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (t.closest('[data-ham-close]') || t === overlay) close();
    });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && overlay.classList.contains('is-open')) close(); });
  }
  initSiteMenu();
</script>
