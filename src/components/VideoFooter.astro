---
// Scroll-scrubbed "video" patička nad footerem (inspirace GEO CrowdVideo).
// hasVideo=false → živé CSS/SVG pozadí (funguje hned). Po vygenerování klipu
// nahrát /assets/footer/scrub.mp4 + poster a přepnout hasVideo=true.
interface Props { hasVideo?: boolean; }
const { hasVideo = false } = Astro.props;
---
<section class="vfoot" data-scrub={hasVideo ? '' : undefined} aria-label="Náskok s AI">
  {hasVideo ? (
    <video class="vfoot-media" muted playsinline preload="none"
      width="1920" height="1080" poster="/assets/footer/scrub-poster.webp">
      <source src="/assets/footer/scrub.mp4" type="video/mp4" />
    </video>
  ) : (
    <div class="vfoot-fallback" aria-hidden="true">
      <div class="grid-floor"></div>
      <div class="aura"></div>
      <svg class="constell" viewBox="0 0 1200 600" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        <g class="lines">
          <line x1="120" y1="180" x2="340" y2="120"/><line x1="340" y1="120" x2="560" y2="220"/>
          <line x1="560" y1="220" x2="820" y2="140"/><line x1="820" y1="140" x2="1040" y2="240"/>
          <line x1="220" y1="360" x2="480" y2="420"/><line x1="480" y1="420" x2="720" y2="360"/>
          <line x1="720" y1="360" x2="960" y2="440"/><line x1="340" y1="120" x2="480" y2="420"/>
          <line x1="560" y1="220" x2="720" y2="360"/>
        </g>
        <g class="dots">
          <circle cx="120" cy="180" r="3"/><circle cx="340" cy="120" r="4"/><circle cx="560" cy="220" r="5"/>
          <circle cx="820" cy="140" r="3"/><circle cx="1040" cy="240" r="4"/><circle cx="220" cy="360" r="3"/>
          <circle cx="480" cy="420" r="5"/><circle cx="720" cy="360" r="4"/><circle cx="960" cy="440" r="3"/>
        </g>
      </svg>
    </div>
  )}

  <div class="vfoot-overlay">
    <div class="wrap">
      <span class="overline"><span class="dot"></span><span class="label vfl">Náskok napřed</span></span>
      <h2>Náskok napřed. Teď&nbsp;i&nbsp;s&nbsp;AI.</h2>
      <a href="/kontakt/" class="btn primary lg">Pojďme to rozjet</a>
    </div>
  </div>
</section>

<style>
  .vfoot {
    position: relative; overflow: hidden;
    width: 100%; height: clamp(380px, 42vw, 600px);
    background: var(--n-900); margin-bottom: -2px;
    display: flex; align-items: center;
  }
  .vfoot-media { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }

  .vfoot-fallback { position: absolute; inset: 0;
    background:
      radial-gradient(80% 60% at 50% 120%, rgba(152,200,0,.18), transparent 60%),
      linear-gradient(180deg, #0e100f, var(--n-900)); }
  .grid-floor {
    position: absolute; left: -25%; right: -25%; bottom: -10%; height: 70%;
    background-image: linear-gradient(rgba(152,200,0,.18) 1px, transparent 1px),
      linear-gradient(90deg, rgba(152,200,0,.18) 1px, transparent 1px);
    background-size: 56px 56px;
    transform: perspective(420px) rotateX(62deg);
    mask-image: linear-gradient(to top, #000 10%, transparent 80%);
    animation: floor 14s linear infinite;
  }
  @keyframes floor { to { background-position: 0 56px, 56px 0; } }
  .aura { position: absolute; inset: 0; background: radial-gradient(50% 40% at 50% 90%, rgba(152,200,0,.22), transparent 70%); }
  .constell { position: absolute; inset: 0; width: 100%; height: 100%; opacity: .8; }
  .constell .lines line { stroke: rgba(152,200,0,.28); stroke-width: 1; }
  .constell .dots circle { fill: var(--lime); animation: twinkle 3.6s ease-in-out infinite; }
  .constell .dots circle:nth-child(2n) { animation-delay: .8s; }
  .constell .dots circle:nth-child(3n) { animation-delay: 1.6s; }
  @keyframes twinkle { 0%,100% { opacity: .35; } 50% { opacity: 1; } }

  .vfoot-overlay { position: relative; z-index: 2; width: 100%; }
  .vfoot-overlay h2 {
    font-size: clamp(34px, 5.5vw, 64px); font-weight: var(--fw-black); letter-spacing: -.025em;
    line-height: 1.02; color: #fff; margin: 14px 0 0; max-width: 16ch;
  }
  .vfoot-overlay .vfl { color: var(--lime); }
  .vfoot-overlay .btn { margin-top: 28px; }

  @media (prefers-reduced-motion: reduce) {
    .grid-floor, .constell .dots circle { animation: none; }
  }
  @media (max-width: 640px) { .vfoot { height: auto; min-height: 460px; padding: 48px 0; } }
</style>
