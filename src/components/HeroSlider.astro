---
// Hero slider — crossfade + Ken Burns + per-slide efekt, tečky + swipe + autoplay.
// Slidy jsou buď fotky (src) nebo grafické 4:3 bannery (banner = varianta HeroBanner).
import HeroBanner from './HeroBanner.astro';
const slides = [
  { src: '/img/hero/hero-1.webp', widths: [480, 900, 1448], alt: 'Vstupte s námi do éry rapidního vývoje s AI — První pozice', pos: '50% 30%', fx: 'kenburns' },
  { src: '/img/hero/hero-2.webp', widths: [480, 1000], alt: 'AI tip pro firmy: Nech agenta psát první verzi', pos: '50% 50%', fx: 'shine' },
  { src: '/img/hero/hero-3.webp', widths: [480, 900, 1448], alt: 'Rychleji, chytřeji, měřitelně — První pozice', pos: '50% 50%', fx: 'pan' },
  { banner: 'stat', alt: '3× rychlejší prototyp díky AI vývoji — První pozice' },
  { src: '/img/hero/hero-4.webp', widths: [480, 900, 1448], alt: 'Náskok. Teď i s AI — První pozice', pos: '50% 50%', fx: 'kenburns' },
  { banner: 'skoleni', alt: 'Školení AI pro firmy na míru — První pozice' },
  // další snímky přidávej sem
];
const multi = slides.length > 1;
// srcset: poslední šířka = originál (hero-X.webp), menší = varianty hero-X-<w>.webp
const srcset = (s: { src: string; widths: number[] }) =>
  s.widths.map((w, i) => `${i === s.widths.length - 1 ? s.src : s.src.replace('.webp', `-${w}.webp`)} ${w}w`).join(', ');
// slider je široký jako .wrap: max 1256 px (1320 − 2×32 padding), jinak plná šířka minus padding
const sizes = '(min-width: 1384px) 1256px, calc(100vw - 64px)';
---
<div class="hslider" data-hero-slider>
  {slides.map((s, i) => (
    <figure class={`hslide${s.banner ? ' is-banner' : ` fx-${s.fx}`}${i === 0 ? ' is-active' : ''}`} data-index={i} aria-label={s.alt}>
      {s.banner ? (
        <HeroBanner variant={s.banner as 'skoleni' | 'stat'} />
      ) : (
        <img src={s.src} srcset={srcset(s as any)} sizes={sizes} alt={s.alt} width="1448" height="1086" style={`object-position:${s.pos}`} loading={i === 0 ? 'eager' : 'lazy'} fetchpriority={i === 0 ? 'high' : undefined} decoding={i === 0 ? 'sync' : 'async'} />
      )}
    </figure>
  ))}
  {multi && (
    <div class="hdots">
      {slides.map((_, i) => <button class={`hdot${i === 0 ? ' is-active' : ''}`} type="button" data-dot={i} aria-label={`Snímek ${i + 1}`}></button>)}
    </div>
  )}
</div>

<script is:inline>
  (function () {
    var root = document.querySelector('[data-hero-slider]');
    if (!root) return;
    var slides = [].slice.call(root.querySelectorAll('.hslide'));
    var dots = [].slice.call(root.querySelectorAll('.hdot'));
    if (slides.length < 2) return;
    var i = 0, timer = null;
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    function show(n) {
      n = (n + slides.length) % slides.length;
      slides[i].classList.remove('is-active');
      if (dots[i]) dots[i].classList.remove('is-active');
      i = n;
      slides[i].classList.add('is-active');
      if (dots[i]) dots[i].classList.add('is-active');
    }
    function start() { if (reduce) return; stop(); timer = setInterval(function () { show(i + 1); }, 5500); }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }
    dots.forEach(function (d, n) {
      d.addEventListener('click', function () { show(n); start(); });
    });
    // swipe
    var x0 = null;
    root.addEventListener('touchstart', function (e) { x0 = e.touches[0].clientX; stop(); }, { passive: true });
    root.addEventListener('touchend', function (e) {
      if (x0 === null) return;
      var dx = e.changedTouches[0].clientX - x0;
      if (Math.abs(dx) > 40) show(i + (dx < 0 ? 1 : -1));
      x0 = null; start();
    }, { passive: true });
    // myš drag (desktop)
    var mx0 = null;
    root.addEventListener('mousedown', function (e) { mx0 = e.clientX; stop(); });
    window.addEventListener('mouseup', function (e) {
      if (mx0 === null) return;
      var dx = e.clientX - mx0;
      if (Math.abs(dx) > 50) show(i + (dx < 0 ? 1 : -1));
      mx0 = null; start();
    });
    start();
  })();
</script>

<style>
  .hslider {
    position: relative; border-radius: var(--radius-2xl); overflow: hidden;
    box-shadow: var(--shadow-xl); border: 1px solid var(--border);
    aspect-ratio: 4 / 3; background: var(--n-900); touch-action: pan-y; user-select: none;
  }
  .hslide { position: absolute; inset: 0; margin: 0; opacity: 0; transition: opacity 1s var(--ease-standard); }
  .hslide.is-active { opacity: 1; z-index: 1; }
  .hslide img { width: 100%; height: 100%; object-fit: cover; display: block; transform: scale(1.02); }
  /* grafický banner — container-query kontext pro --u škálování v HeroBanner */
  .hslide.is-banner { container-type: inline-size; }

  /* Efekt 1 — Ken Burns (pomalý zoom in) */
  .fx-kenburns.is-active img { animation: kenburns 14s ease-out forwards; }
  @keyframes kenburns { from { transform: scale(1.02); } to { transform: scale(1.09); } }

  /* Efekt 2 — pomalý zoom out + diagonální „shine" přejezd přes kartu */
  .fx-shine.is-active img { animation: zoomout 14s ease-out forwards; }
  @keyframes zoomout { from { transform: scale(1.1); } to { transform: scale(1.0); } }
  .fx-shine::after {
    content: ""; position: absolute; inset: -30%;
    background: linear-gradient(115deg, transparent 40%, rgba(152,200,0,.16) 50%, transparent 60%);
    transform: translateX(-120%); pointer-events: none;
  }
  .fx-shine.is-active::after { animation: shine 2.4s var(--ease-standard) .4s 1; }
  @keyframes shine { to { transform: translateX(120%); } }

  /* Efekt 3 — jemný horizontální pan + lehký zoom */
  .fx-pan.is-active img { animation: pan 14s ease-out forwards; }
  @keyframes pan { from { transform: scale(1.08) translateX(-2%); } to { transform: scale(1.08) translateX(2%); } }

  /* tečky s průsvitným tmavým podkladem — čitelné na fotce i světlém/tmavém banneru */
  .hdots { position: absolute; bottom: 8px; left: 50%; transform: translateX(-50%); z-index: 5; display: flex; align-items: center; justify-content: center; gap: 2px; padding: 3px 6px; border-radius: 999px; background: rgba(29,31,30,.32); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); }
  /* tap target ≥24×24 (a11y), vizuální tečka je ::after uvnitř */
  .hdot { width: 24px; height: 24px; border: 0; padding: 0; background: transparent; cursor: pointer; display: flex; align-items: center; justify-content: center; }
  .hdot::after { content: ""; width: 8px; height: 8px; border-radius: 999px; background: rgba(255,255,255,.6); transition: background var(--dur-base), width var(--dur-base); }
  .hdot:hover::after { background: rgba(255,255,255,.9); }
  .hdot.is-active::after { background: var(--lime); width: 22px; }

  @media (prefers-reduced-motion: reduce) {
    .hslide.is-active img { animation: none; transform: none; }
    .fx-shine.is-active::after { animation: none; }
  }
</style>
