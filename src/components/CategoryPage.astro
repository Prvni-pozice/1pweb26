---
import Base from '../layouts/Base.astro';
import ShowcaseCard from './ShowcaseCard.astro';
import references from '../data/references.json';
import categories from '../data/categories.json';
import eshopGraphics from '../data/eshop_graphics.json';

interface Props { cat: 'weby' | 'eshopy' | 'marketing'; }
const { cat } = Astro.props;
const c = (categories as any)[cat];
const refs = (references as any[]).filter((r) => r.cat === cat);
const metaTitle = `${c.eyebrow.split('· ')[1]} — První pozice`;
---
<Base title={metaTitle} description={c.lead.replace(/<[^>]+>/g, '')}>
  <header class="page-hero">
    <div class="wrap">
      <span class="overline"><span class="dot"></span><span class="label">{c.eyebrow}</span></span>
      <h1 set:html={c.title} />
      <p class="lead">{c.lead}</p>
      <div class="cta">
        <a href="/kontakt/" class="btn primary lg">{c.ctaLabel}</a>
        <a href="#reference" class="btn secondary">Naše reference</a>
      </div>
    </div>
  </header>

  <section class="section feature-sec">
    <div class="wrap">
      <div class="features">
        {c.features.map((f: any) => (
          <div class="feat">
            <div class="feat-mark"></div>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="reference">
    <div class="wrap">
      <div class="sec-head">
        <span class="overline"><span class="dot"></span><span class="label">Již jsme pomohli</span></span>
        <h2>{c.gridTitle} <span class="count">{refs.length}</span></h2>
        <p>{c.gridLead}</p>
      </div>
      <div class="grid">
        {refs.map((r) => (
          <ShowcaseCard name={r.name} href={`/reference/${r.slug}/`} img={r.img} bullets={r.bullets} />
        ))}
      </div>
    </div>
  </section>

  {c.showEshopGraphics && (
    <section class="section graphics-sec">
      <div class="wrap">
        <div class="sec-head">
          <span class="overline"><span class="dot"></span><span class="label">Proč e-shop od 1P</span></span>
          <h2>Na čem si zakládáme</h2>
        </div>
        <div class="graphics">
          {eshopGraphics.map((g: any, i: number) => (
            <div class={`grow${i % 2 ? ' rev' : ''}`}>
              <div class="g-img"><img src={g.img} alt={g.title} loading="lazy" /></div>
              <div class="g-txt">
                <h3>{g.title}</h3>
                <p>{g.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="wrap">
      <div class="cta-band">
        <div>
          <h2>Pojďme postavit i ten váš.</h2>
          <p>Nezávazná konzultace zdarma. Řekneme vám rovnou, co dává smysl právě pro vás.</p>
        </div>
        <a href="/kontakt/" class="btn dark lg cta-btn">Domluvit konzultaci</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-hero { padding: 72px 0 8px; }
  .page-hero h1 { font-size: var(--fs-display-xl); font-weight: var(--fw-black); letter-spacing: -.025em; line-height: 1.04; color: var(--text-strong); margin: 18px 0 0; }
  .page-hero :global(h1 u) { text-decoration: none; box-shadow: inset 0 -.12em 0 var(--lime); }
  .page-hero .lead { font-size: 20px; line-height: var(--lh-body); color: var(--text-muted); max-width: 620px; margin: 24px 0 0; }
  .page-hero .cta { display: flex; gap: 14px; margin-top: 30px; flex-wrap: wrap; }

  .feature-sec { padding-top: 64px; padding-bottom: 32px; }
  .features { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; }
  .feat-mark { width: 36px; height: 36px; border-radius: var(--radius-md); background: var(--lime-100); position: relative; margin-bottom: 16px; }
  .feat-mark::after { content: ""; position: absolute; inset: 13px; border-radius: var(--radius-pill); background: var(--lime); }
  .feat h3 { font-size: 19px; font-weight: var(--fw-bold); color: var(--text-strong); }
  .feat p { font-size: 15px; line-height: var(--lh-body); color: var(--text-muted); margin-top: 8px; }

  .sec-head h2 .count { font-size: 22px; font-weight: var(--fw-bold); color: var(--lime-800); vertical-align: super; margin-left: 6px; }
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 44px; }

  .graphics-sec { background: var(--surface-sunken); border-radius: var(--radius-2xl); padding: 80px 0; }
  .graphics { display: grid; gap: 28px; margin-top: 44px; }
  .grow { display: grid; grid-template-columns: 1.1fr 1fr; gap: 40px; align-items: center; background: #fff; border: 1px solid var(--border); border-radius: var(--radius-xl); overflow: hidden; }
  .grow.rev { grid-template-columns: 1fr 1.1fr; }
  .grow.rev .g-img { order: 2; }
  .g-img { background: var(--n-50); height: 100%; min-height: 240px; display: flex; align-items: center; justify-content: center; }
  .g-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .g-txt { padding: 36px 40px; }
  .g-txt h3 { font-size: var(--fs-title-md); font-weight: var(--fw-bold); color: var(--text-strong); }
  .g-txt p { font-size: 16px; line-height: var(--lh-body); color: var(--text-muted); margin-top: 12px; }

  .cta-band { background: var(--lime); border-radius: var(--radius-2xl); padding: 64px 56px; display: flex; align-items: center; justify-content: space-between; gap: 40px; }
  .cta-band h2 { font-size: var(--fs-display-md); font-weight: var(--fw-black); letter-spacing: var(--ls-display); color: var(--n-900); line-height: 1.05; }
  .cta-band p { font-size: 18px; color: var(--lime-900); margin-top: 12px; max-width: 480px; }
  .cta-btn { flex: none; }

  @media (max-width: 980px) {
    .features { grid-template-columns: repeat(2, 1fr); }
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 760px) {
    .page-hero h1 { font-size: 40px; }
    .grid { grid-template-columns: 1fr; }
    .grow, .grow.rev { grid-template-columns: 1fr; }
    .grow.rev .g-img { order: 0; }
    .cta-band { flex-direction: column; align-items: flex-start; padding: 40px 28px; }
  }
</style>
