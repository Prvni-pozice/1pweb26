---
// Bohatá section-root stránka (weby / eshopy / marketing) — tree-driven karty.
import Breadcrumbs from './Breadcrumbs.astro';
import ShowcaseCard from './ShowcaseCard.astro';
import categories from '../data/categories.json';
import eshopGraphics from '../data/eshop_graphics.json';

interface Props { cat: 'weby' | 'eshopy' | 'marketing'; pathKey: string; kids: any[]; }
const { cat, pathKey, kids } = Astro.props;
const c = (categories as any)[cat];

const cardChildren = kids.filter((x: any) => x.thumb);
const restChildren = kids.filter((x: any) => !x.thumb);
const montage = cardChildren.slice(0, 4).map((x: any) => x.thumb);
const GRID_TITLE: Record<string, string> = {
  weby: 'Pomohli jsme těmto projektům',
  eshopy: 'Reference e-shopů',
  marketing: 'Naše služby',
};
const isMarketing = cat === 'marketing';
---
<div class="sr">
  <div class="wrap">
    <Breadcrumbs path={pathKey} />
    <header class="sr-hero">
      <div class="sr-hero-txt">
        <span class="overline"><span class="dot"></span><span class="label">{c.eyebrow}</span></span>
        <h1 set:html={c.title} />
        <p class="lead">{c.lead}</p>
        <div class="cta">
          <a href="/kontakt/" class="btn primary lg">{c.ctaLabel}</a>
          <a href="#vypis" class="btn secondary">{isMarketing ? 'Naše služby' : 'Reference'}</a>
        </div>
      </div>
      {montage.length >= 2 && (
        <div class={`sr-montage m${Math.min(montage.length, 4)}`} aria-hidden="true">
          {montage.map((src: string) => <div class="mt"><img src={src} alt="" loading="lazy" /></div>)}
        </div>
      )}
    </header>

    <section class="sr-features">
      {c.features.map((f: any) => (
        <div class="feat"><div class="feat-mark"></div><h2>{f.title}</h2><p>{f.desc}</p></div>
      ))}
    </section>

    <section class="sr-list" id="vypis">
      <h2 class="sr-list-h">{GRID_TITLE[cat]} <span class="count">{cardChildren.length}</span></h2>
      <div class="grid" data-reveal-group>
        {cardChildren.map((x: any) => (
          <ShowcaseCard name={x.label} href={x.path} img={x.thumb} />
        ))}
      </div>
    </section>

    {cat === 'eshopy' && (
      <section class="sr-graphics">
        <h2 class="sr-list-h">Na čem si zakládáme</h2>
        <div class="gfx">
          {eshopGraphics.map((g: any, i: number) => (
            <div class={`grow${i % 2 ? ' rev' : ''}`}>
              <div class="g-img"><img src={g.img} alt={g.title} loading="lazy" /></div>
              <div class="g-txt"><h3>{g.title}</h3><p>{g.text}</p></div>
            </div>
          ))}
        </div>
      </section>
    )}

    {restChildren.length > 0 && (
      <section class="sr-list">
        <h2 class="sr-list-h">Další v této sekci</h2>
        <ul class="rest">
          {restChildren.map((x: any) => <li><a href={x.path}>{x.label} →</a></li>)}
        </ul>
      </section>
    )}
  </div>

  <div class="wrap">
    <div class="cta-band">
      <div><h2>Pojďme postavit i ten váš.</h2><p>Nezávazná konzultace zdarma.</p></div>
      <a href="/kontakt/" class="btn dark lg" style="flex:none">Domluvit konzultaci</a>
    </div>
  </div>
</div>

<style>
  .sr { padding: 32px 0 0; }
  .sr-hero { display: grid; grid-template-columns: 1.05fr .95fr; gap: 48px; align-items: center; margin-top: 22px; }
  .sr-hero h1 { font-size: var(--fs-display-xl); font-weight: var(--fw-black); letter-spacing: -.025em; line-height: 1.04; color: var(--text-strong); margin: 16px 0 0; }
  .sr-hero :global(h1 u) { text-decoration: none; box-shadow: inset 0 -.12em 0 var(--lime); }
  .sr-hero .lead { font-size: 19px; line-height: var(--lh-body); color: var(--text-muted); margin: 22px 0 0; max-width: 540px; }
  .sr-hero .cta { display: flex; gap: 14px; margin-top: 28px; flex-wrap: wrap; }

  .sr-montage { display: grid; gap: 14px; }
  .sr-montage.m4, .sr-montage.m3 { grid-template-columns: 1fr 1fr; }
  .sr-montage.m2 { grid-template-columns: 1fr 1fr; }
  .mt { border-radius: var(--radius-lg); overflow: hidden; aspect-ratio: 4/3; box-shadow: var(--shadow-md); border: 1px solid var(--border); }
  .mt:nth-child(2) { transform: translateY(18px); }
  .mt:nth-child(3) { transform: translateY(-18px); }
  .mt img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .sr-features { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; margin-top: 72px; }
  .feat-mark { width: 36px; height: 36px; border-radius: var(--radius-md); background: var(--lime-100); position: relative; margin-bottom: 16px; }
  .feat-mark::after { content: ""; position: absolute; inset: 13px; border-radius: var(--radius-pill); background: var(--lime); }
  .feat h2 { font-size: 19px; font-weight: var(--fw-bold); color: var(--text-strong); }
  .feat p { font-size: 15px; line-height: var(--lh-body); color: var(--text-muted); margin-top: 8px; }

  .sr-list { margin-top: 64px; }
  .sr-list-h { font-size: var(--fs-title-lg); font-weight: var(--fw-black); letter-spacing: -.018em; color: var(--text-strong); }
  .sr-list-h .count { font-size: 18px; color: var(--lime-800); vertical-align: super; margin-left: 6px; }
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 24px; }
  .rest { list-style: none; margin: 20px 0 0; padding: 0; display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; }
  .rest a { font-size: 15px; color: var(--text); }
  .rest a:hover { color: var(--lime-800); }

  .sr-graphics { margin-top: 72px; background: var(--surface-sunken); border-radius: var(--radius-2xl); padding: 56px 40px; }
  .gfx { display: grid; gap: 24px; margin-top: 28px; }
  .grow { display: grid; grid-template-columns: 1.1fr 1fr; gap: 36px; align-items: center; background: #fff; border: 1px solid var(--border); border-radius: var(--radius-xl); overflow: hidden; }
  .grow.rev { grid-template-columns: 1fr 1.1fr; }
  .grow.rev .g-img { order: 2; }
  .g-img { background: var(--n-50); min-height: 220px; }
  .g-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .g-txt { padding: 32px 36px; }
  .g-txt h3 { font-size: var(--fs-title-md); font-weight: var(--fw-bold); color: var(--text-strong); }
  .g-txt p { font-size: 16px; line-height: var(--lh-body); color: var(--text-muted); margin-top: 10px; }

  .cta-band { background: var(--lime); border-radius: var(--radius-2xl); padding: 56px 48px; margin-top: 72px; display: flex; align-items: center; justify-content: space-between; gap: 40px; }
  .cta-band h2 { font-size: var(--fs-display-md); font-weight: var(--fw-black); letter-spacing: var(--ls-display); color: var(--n-900); }
  .cta-band p { font-size: 18px; color: var(--lime-900); margin-top: 10px; }

  @media (max-width: 980px) {
    .sr-hero { grid-template-columns: 1fr; gap: 32px; }
    .sr-features { grid-template-columns: repeat(2, 1fr); }
    .grid { grid-template-columns: repeat(2, 1fr); }
    .rest { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 680px) {
    .sr-hero h1 { font-size: 40px; }
    .grid { grid-template-columns: 1fr; }
    .grow, .grow.rev { grid-template-columns: 1fr; }
    .grow.rev .g-img { order: 0; }
    .cta-band { flex-direction: column; align-items: flex-start; padding: 36px 26px; }
  }
</style>
