---
// Globální layout: hlavička, design-systém tokeny (src/styles/global.css), Nav + Footer.
// Self-hostované fonty (Roboto + Roboto Mono) — pouze latin + latin-ext (CZ web).
import '../styles/global.css';
import '@fontsource/roboto/latin-400.css';
import '@fontsource/roboto/latin-ext-400.css';
import '@fontsource/roboto/latin-500.css';
import '@fontsource/roboto/latin-ext-500.css';
import '@fontsource/roboto/latin-700.css';
import '@fontsource/roboto/latin-ext-700.css';
import '@fontsource/roboto/latin-900.css';
import '@fontsource/roboto/latin-ext-900.css';
import '@fontsource/roboto-mono/latin-400.css';
import '@fontsource/roboto-mono/latin-ext-400.css';
import '@fontsource/roboto-mono/latin-500.css';
import '@fontsource/roboto-mono/latin-ext-500.css';
// Preload kritických řezů (LCP): 900 = display nadpisy, 400 = běžný text.
// ?url vrací stejnou hashovanou URL, jakou má soubor v bundlovaném CSS.
import fontBlackExt from '@fontsource/roboto/files/roboto-latin-ext-900-normal.woff2?url';
import fontBlack from '@fontsource/roboto/files/roboto-latin-900-normal.woff2?url';
import fontRegularExt from '@fontsource/roboto/files/roboto-latin-ext-400-normal.woff2?url';
import fontRegular from '@fontsource/roboto/files/roboto-latin-400-normal.woff2?url';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import VideoFooter from '../components/VideoFooter.astro';
import SiteMenuOverlay from '../components/SiteMenuOverlay.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title = 'První pozice — Náskok napřed s AI',
  description = 'Lokální internetová agentura. Weby, e-shopy a aplikace — a posun dál pomocí AI nástrojů a agentů. Rychleji, chytřeji, měřitelně.',
  ogImage,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage ?? 'https://www.prvni-pozice.com/img/hero/hero-1.webp';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'První pozice, s.r.o.',
  url: 'https://www.prvni-pozice.com',
  telephone: '+420775387231',
  email: 'podpora@prvni-pozice.com',
  description: 'Lokální internetová agentura. Weby, e-shopy a aplikace — a posun dál pomocí AI nástrojů a agentů.',
  image: 'https://www.prvni-pozice.com/img/hero/hero-1.webp',
  areaServed: 'CZ',
  knowsLanguage: 'cs',
};
---
<!doctype html>
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1000" />
    <meta property="og:image:height" content="1250" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <slot name="head" />
    <link rel="preload" href={fontBlackExt} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={fontBlack} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={fontRegularExt} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={fontRegular} as="font" type="font/woff2" crossorigin />
    <!-- reveal-on-scroll skrývá obsah jen když běží JS (jinak je vždy vidět) -->
    <script is:inline>document.documentElement.classList.add('js');</script>
    <script src="/js/motion.js" defer></script>
    <script is:inline>
      // GA4 — dataLayer se plní hned, samotný gtag.js (152 KiB) se stáhne až
      // po první interakci, nejpozději 3,5 s po load (ať neblokuje LCP/TBT).
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-5XDVHLWRP4');
      (function () {
        var done = false;
        function loadGtag() {
          if (done) return; done = true;
          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-5XDVHLWRP4';
          document.head.appendChild(s);
        }
        ['pointerdown', 'keydown', 'scroll', 'touchstart'].forEach(function (e) {
          addEventListener(e, loadGtag, { passive: true, once: true });
        });
        addEventListener('load', function () { setTimeout(loadGtag, 3500); });
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Přeskočit na obsah</a>
    <Nav />
    <SiteMenuOverlay />
    <main id="main-content">
      <slot />
    </main>
    <VideoFooter />
    <Footer />
  </body>
</html>

<style is:global>
  /* Sdílené layout primitivy z design-systému UI kitu (web).
     Globální, protože je sdílí Nav, hero i CTA napříč komponentami. */
  .wrap { max-width: var(--container-wide); margin: 0 auto; padding: 0 var(--space-8); }

  .overline { display: inline-flex; align-items: center; gap: 9px; }
  .overline .dot { width: 7px; height: 7px; border-radius: var(--radius-pill); background: var(--lime); }
  .overline .label {
    font-family: var(--font-mono); font-size: var(--fs-overline);
    letter-spacing: var(--ls-overline); text-transform: uppercase; color: var(--accent-ink);
  }

  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    font-family: var(--font-sans); font-weight: var(--fw-medium);
    border-radius: var(--radius-pill); border: 1.5px solid transparent;
    cursor: pointer; text-decoration: none;
    transition: background var(--dur-base) var(--ease-standard), box-shadow var(--dur-base) var(--ease-standard);
  }
  .btn.primary { background: var(--lime); color: var(--n-900); box-shadow: var(--shadow-sm); padding: 11px 22px; font-size: 15px; }
  .btn.primary:hover { background: var(--lime-600); box-shadow: var(--shadow-lime); }
  .btn.dark { background: var(--n-900); color: #fff; padding: 11px 22px; font-size: 15px; }
  .btn.dark:hover { background: var(--n-800); }
  .btn.ghost { background: transparent; color: var(--text); padding: 11px 14px; font-size: 15px; }
  .btn.ghost:hover { color: var(--lime-800); }
  .btn.secondary { background: #fff; color: var(--text-strong); border-color: var(--border-strong); padding: 14px 28px; font-size: 17px; }
  .btn.secondary:hover { border-color: var(--n-400); }
  .btn.lg { padding: 15px 30px; font-size: 17px; }

  .btn:focus-visible { outline: none; box-shadow: var(--ring); }

  .section { padding: var(--section-y) 0; }
  .sec-head { max-width: 660px; }
  .sec-head h2 { font-size: var(--fs-display-lg); font-weight: var(--fw-black); letter-spacing: var(--ls-display); line-height: 1.08; color: var(--text-strong); margin: 14px 0 0; }
  .sec-head p { font-size: var(--fs-body-lg); color: var(--text-muted); margin: 18px 0 0; line-height: var(--lh-body); }

  @media (max-width: 760px) {
    .sec-head h2 { font-size: var(--fs-display-md); }
  }

  .skip-link {
    position: absolute; top: -100%; left: 0;
    background: var(--lime); color: var(--n-900);
    padding: 10px 20px; font-weight: var(--fw-bold);
    z-index: 9999; text-decoration: none;
    border-radius: 0 0 var(--radius-md) 0;
  }
  .skip-link:focus { top: 0; }

  /* Reveal on scroll (motion.js) — skryté JEN když běží JS (html.js) */
  .js [data-reveal], .js [data-reveal-group] > * {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity .6s var(--ease-out), transform .6s var(--ease-out);
    will-change: opacity, transform;
  }
  .js [data-reveal].is-visible, .js [data-reveal-group].is-visible > * {
    opacity: 1;
    transform: none;
  }

  /* Pointer glow — real DOM element pohybovaný přes style.transform (čistě compositor) */
  [data-glow] { position: relative; isolation: isolate; overflow: hidden; }
  .glow-orb {
    position: absolute; width: 280px; height: 280px; left: 0; top: 0;
    border-radius: 50%; pointer-events: none; z-index: 0;
    background: radial-gradient(circle, rgba(152,200,0,.18) 0%, transparent 65%);
    opacity: 0; transition: opacity .35s var(--ease-out);
    will-change: transform, opacity;
    transform: translate(-140px, -140px);
  }
  [data-glow]:hover .glow-orb { opacity: 1; }
  [data-glow] > *:not(.glow-orb) { position: relative; z-index: 1; }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal], [data-reveal-group] > * { opacity: 1 !important; transform: none !important; }
  }
</style>
