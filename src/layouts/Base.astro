---
// Globální layout: hlavička, design-systém tokeny (/styles.css), Nav + Footer.
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'První pozice — Náskok napřed s AI',
  description = 'Lokální internetová agentura. Weby, e-shopy a aplikace — a posun dál pomocí AI nástrojů a agentů. Rychleji, chytřeji, měřitelně.',
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <Nav />
    <slot />
    <Footer />
  </body>
</html>

<style is:global>
  /* Sdílené layout primitivy z design-systému UI kitu (web).
     Globální, protože je sdílí Nav, hero i CTA napříč komponentami. */
  .wrap { max-width: var(--container-wide); margin: 0 auto; padding: 0 var(--space-8); }

  .overline { display: inline-flex; align-items: center; gap: 9px; }
  .overline .dot { width: 7px; height: 7px; border-radius: var(--radius-pill); background: var(--lime); }
  .overline .label {
    font-family: var(--font-mono); font-size: var(--fs-overline);
    letter-spacing: var(--ls-overline); text-transform: uppercase; color: var(--accent-ink);
  }

  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    font-family: var(--font-sans); font-weight: var(--fw-medium);
    border-radius: var(--radius-pill); border: 1.5px solid transparent;
    cursor: pointer; text-decoration: none;
    transition: background var(--dur-base) var(--ease-standard), box-shadow var(--dur-base) var(--ease-standard);
  }
  .btn.primary { background: var(--lime); color: var(--n-900); box-shadow: var(--shadow-sm); padding: 11px 22px; font-size: 15px; }
  .btn.primary:hover { background: var(--lime-600); box-shadow: var(--shadow-lime); }
  .btn.dark { background: var(--n-900); color: #fff; padding: 11px 22px; font-size: 15px; }
  .btn.dark:hover { background: var(--n-800); }
  .btn.ghost { background: transparent; color: var(--text); padding: 11px 14px; font-size: 15px; }
  .btn.ghost:hover { color: var(--lime-800); }
  .btn.secondary { background: #fff; color: var(--text-strong); border-color: var(--border-strong); padding: 14px 28px; font-size: 17px; }
  .btn.secondary:hover { border-color: var(--n-400); }
  .btn.lg { padding: 15px 30px; font-size: 17px; }

  .btn:focus-visible { outline: none; box-shadow: var(--ring); }

  .section { padding: var(--section-y) 0; }
  .sec-head { max-width: 660px; }
  .sec-head h2 { font-size: var(--fs-display-lg); font-weight: var(--fw-black); letter-spacing: var(--ls-display); line-height: 1.08; color: var(--text-strong); margin: 14px 0 0; }
  .sec-head p { font-size: var(--fs-body-lg); color: var(--text-muted); margin: 18px 0 0; line-height: var(--lh-body); }

  @media (max-width: 760px) {
    .sec-head h2 { font-size: var(--fs-display-md); }
  }
</style>
