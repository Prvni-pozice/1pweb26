---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ShowcaseCard from '../components/ShowcaseCard.astro';
import ListCard from '../components/ListCard.astro';
import site from '../data/site.json';

const map = site as Record<string, any>;

export function getStaticPaths() {
  const m = site as Record<string, any>;
  return Object.keys(m).map((p) => ({
    params: { path: p.replace(/^\/|\/$/g, '') },
    props: { node: m[p], pathKey: p },
  }));
}
const { node, pathKey } = Astro.props;
const children = (node.children || []).map((c: string) => map[c]).filter(Boolean);
// Referenční karta (ShowcaseCard) jen pro klientské reference pod /weby/ nebo /eshopy/.
const isRefCard = (c: any) => /^\/(weby|eshopy)\//.test(c.path) && c.thumb;
const childRefs = children.filter(isRefCard);
const childOther = children.filter((c: any) => !isRefCard(c));
let host = '';
try { if (node.ext) host = new URL(node.ext).host.replace(/^www\./, ''); } catch {}

const KIND: Record<string, string> = { hub: 'Sekce', article: 'Článek', reference: 'Reference' };
const metaDesc = node.intro || `${node.label} — První pozice.`;
---
<Base title={`${node.label} — První pozice`} description={metaDesc.slice(0, 155)}>
  <article class="node">
    <div class="wrap">
      <Breadcrumbs path={pathKey} />
      <h1>{node.label}</h1>

      {node.thumb && (
        <div class="node-hero"><img src={node.thumb} alt={node.label} loading="lazy" /></div>
      )}

      <div class="node-body">
        <div class="node-main">
          {node.content
            ? <div class="prose" set:html={node.content} />
            : node.intro && <p class="prose-lead">{node.intro}</p>}
        </div>

        {(host || true) && (
          <aside class="node-aside">
            {host && (
              <div class="visit">
                <span class="overline"><span class="dot"></span><span class="label">Web klienta</span></span>
                <a class="visit-link" href={node.ext} target="_blank" rel="noopener noreferrer">{host} →</a>
              </div>
            )}
            <div class="cta-card">
              <h3>Chcete podobný projekt?</h3>
              <p>Ozvěte se — nezávazně probereme, co dává smysl právě pro vás.</p>
              <a href="/kontakt/" class="btn primary">Domluvit konzultaci</a>
            </div>
          </aside>
        )}
      </div>

      {childRefs.length > 0 && (
        <section class="kids">
          <h2 class="kids-title">Reference <span class="count">{childRefs.length}</span></h2>
          <div class="grid" data-reveal-group>
            {childRefs.map((c: any) => (
              <ShowcaseCard name={c.label} href={c.path} img={c.thumb} />
            ))}
          </div>
        </section>
      )}

      {childOther.length > 0 && (
        <section class="kids">
          <h2 class="kids-title">{childRefs.length > 0 ? 'Další v této sekci' : 'Obsah sekce'}</h2>
          <div class="lgrid" data-reveal-group>
            {childOther.map((c: any) => (
              <ListCard href={c.path} label={c.label} intro={c.intro} kind={KIND[c.type]} />
            ))}
          </div>
        </section>
      )}
    </div>
  </article>
</Base>

<style>
  .node { padding: 40px 0 24px; }
  .node h1 { font-size: var(--fs-display-md); font-weight: var(--fw-black); letter-spacing: -.022em; color: var(--text-strong); margin: 18px 0 0; max-width: 22ch; }
  .node-hero { margin-top: 28px; border-radius: var(--radius-2xl); overflow: hidden; box-shadow: var(--shadow-xl); border: 1px solid var(--border); aspect-ratio: 16 / 9; max-width: 760px; }
  .node-hero img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .node-body { display: grid; grid-template-columns: 1fr 320px; gap: 48px; margin-top: 40px; align-items: start; }
  .node-main { min-width: 0; }
  .prose :global(h2) { font-size: var(--fs-title-lg); font-weight: var(--fw-bold); color: var(--text-strong); margin: 32px 0 0; }
  .prose :global(h3) { font-size: var(--fs-title-sm); font-weight: var(--fw-bold); color: var(--text-strong); margin: 26px 0 0; }
  .prose :global(p) { font-size: 17px; line-height: var(--lh-relaxed); color: var(--text); margin: 14px 0 0; }
  .prose :global(ul), .prose :global(ol) { margin: 14px 0 0; padding-left: 22px; }
  .prose :global(li) { font-size: 17px; line-height: var(--lh-body); color: var(--text); margin: 6px 0; }
  .prose :global(a) { color: var(--lime-800); text-decoration: underline; text-underline-offset: 2px; }
  .prose :global(img) { max-width: 100%; height: auto; border-radius: var(--radius-lg); margin: 20px 0 0; }
  .prose :global(strong) { color: var(--text-strong); }
  .prose-lead { font-size: 19px; line-height: var(--lh-relaxed); color: var(--text-muted); }

  .node-aside { display: grid; gap: 18px; position: sticky; top: 90px; }
  .visit { background: var(--n-900); border-radius: var(--radius-xl); padding: 20px 22px; }
  .visit :global(.label) { color: var(--lime); }
  .visit-link { display: inline-block; margin-top: 8px; font-size: 17px; font-weight: var(--fw-bold); color: #fff; }
  .visit-link:hover { color: var(--lime); }
  .cta-card { background: var(--surface-sunken); border: 1px solid var(--border); border-radius: var(--radius-xl); padding: 24px; }
  .cta-card h3 { font-size: 18px; font-weight: var(--fw-bold); color: var(--text-strong); }
  .cta-card p { font-size: 14px; line-height: var(--lh-body); color: var(--text-muted); margin: 8px 0 16px; }

  .kids { margin-top: 56px; }
  .kids-title { font-size: var(--fs-title-lg); font-weight: var(--fw-black); letter-spacing: -.018em; color: var(--text-strong); }
  .kids-title .count { font-size: 18px; color: var(--lime-800); vertical-align: super; margin-left: 6px; }
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 24px; }
  .lgrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin-top: 24px; }

  @media (max-width: 980px) {
    .node-body { grid-template-columns: 1fr; gap: 28px; }
    .node-aside { position: static; }
    .grid, .lgrid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 680px) { .grid, .lgrid { grid-template-columns: 1fr; } }
</style>
