    color: var(--text-strong);
    margin: 40px 0 12px;
    padding-top: 8px;
    border-top: 1px solid var(--border);
  }
  .prose-legal p, .prose-legal li {
    font-size: 16px;
    line-height: 1.7;
    color: var(--text);
  }
  .prose-legal ul { padding-left: 20px; margin: 10px 0; }
  .prose-legal li { margin-bottom: 6px; }
