---
import Base from '../../layouts/Base.astro';
import ShowcaseCard from '../../components/ShowcaseCard.astro';
import eshopy from '../../data/eshopy.json';

const features = [
  { title: 'Rychlost', desc: 'Optimalizované načítání a Core Web Vitals v zelených číslech. Rychlý e-shop prodává víc.' },
  { title: 'Responzivita', desc: 'Dokonalé zobrazení na mobilu, tabletu i desktopu. Většina nákupů začíná na telefonu.' },
  { title: 'Design dle značky', desc: 'Moderní vzhled, který drží vaši firemní identitu — ne šablona z police.' },
  { title: 'Nejnovější technologie', desc: 'Stabilní, bezpečné a snadno rozšiřitelné řešení připravené na růst.' },
];
---
<Base
  title="E-shopy na míru — První pozice"
  description="Tvorba úspěšných e-shopů na míru: rychlost, responzivita, moderní design dle vaší značky a nejnovější technologie. Podívejte se na naše reference."
>
  <header class="page-hero">
    <div class="wrap">
      <span class="overline"><span class="dot"></span><span class="label">Služby · E-shopy</span></span>
      <h1>E-shopy, které <u>prodávají</u>.</h1>
      <p class="lead">Stavíme e-shopy na míru — rychlé, čisté a postavené na měřitelných výsledcích. Od návrhu přes kódování po provoz a růst.</p>
      <div class="cta">
        <a href="/kontakt/" class="btn primary lg">Chci e-shop</a>
        <a href="#reference" class="btn secondary">Naše reference</a>
      </div>
    </div>
  </header>

  <section class="section feature-sec">
    <div class="wrap">
      <div class="features">
        {features.map((f) => (
          <div class="feat">
            <div class="feat-mark"></div>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="reference">
    <div class="wrap">
      <div class="sec-head">
        <span class="overline"><span class="dot"></span><span class="label">Již jsme pomohli</span></span>
        <h2>Reference e-shopů</h2>
        <p>Výběr e-shopů, které jsme postavili a dál rozvíjíme.</p>
      </div>
      <div class="grid">
        {eshopy.map((e) => (
          <ShowcaseCard name={e.name} href={`/reference/${e.slug}/`} img={e.img} bullets={e.bullets} />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="cta-band">
        <div>
          <h2>Pojďme postavit i ten váš.</h2>
          <p>Nezávazná konzultace zdarma. Řekneme vám rovnou, co váš e-shop potřebuje.</p>
        </div>
        <a href="/kontakt/" class="btn dark lg cta-btn">Domluvit konzultaci</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-hero { padding: 72px 0 8px; }
  .page-hero h1 { font-size: var(--fs-display-xl); font-weight: var(--fw-black); letter-spacing: -.025em; line-height: 1.04; color: var(--text-strong); margin: 18px 0 0; }
  .page-hero h1 u { text-decoration: none; box-shadow: inset 0 -.12em 0 var(--lime); }
  .page-hero .lead { font-size: 20px; line-height: var(--lh-body); color: var(--text-muted); max-width: 620px; margin: 24px 0 0; }
  .page-hero .cta { display: flex; gap: 14px; margin-top: 30px; flex-wrap: wrap; }

  .feature-sec { padding-top: 64px; padding-bottom: 32px; }
  .features { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; }
  .feat-mark { width: 36px; height: 36px; border-radius: var(--radius-md); background: var(--lime-100); position: relative; margin-bottom: 16px; }
  .feat-mark::after { content: ""; position: absolute; inset: 13px; border-radius: var(--radius-pill); background: var(--lime); }
  .feat h3 { font-size: 19px; font-weight: var(--fw-bold); color: var(--text-strong); }
  .feat p { font-size: 15px; line-height: var(--lh-body); color: var(--text-muted); margin-top: 8px; }

  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 44px; }

  .cta-band { background: var(--lime); border-radius: var(--radius-2xl); padding: 64px 56px; display: flex; align-items: center; justify-content: space-between; gap: 40px; }
  .cta-band h2 { font-size: var(--fs-display-md); font-weight: var(--fw-black); letter-spacing: var(--ls-display); color: var(--n-900); line-height: 1.05; }
  .cta-band p { font-size: 18px; color: var(--lime-900); margin-top: 12px; max-width: 480px; }
  .cta-btn { flex: none; }

  @media (max-width: 980px) {
    .features { grid-template-columns: repeat(2, 1fr); }
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 760px) {
    .page-hero h1 { font-size: 40px; }
    .grid { grid-template-columns: 1fr; }
    .cta-band { flex-direction: column; align-items: flex-start; padding: 40px 28px; }
  }
</style>
