---
import Base from '../../layouts/Base.astro';

// Kontakt — dle DS předlohy ui_kits/website/kontakt.html, s reálnými údaji ze starého webu.
const contact = {
  person: 'Václav Tůma',
  role: 'zákaznická podpora',
  tel: '+420 775 387 231',
  telHref: 'tel:+420775387231',
  email: 'podpora@prvni-pozice.com',
  company: 'První pozice, s.r.o.',
  ico: '29136334',
  dic: 'CZ29136334',
};
const interests = ['AI aplikace', 'Web / e-shop', 'AI školení', 'Online marketing', 'AI agenti'];

// Všechna oddělení a adresy převzaté ze starého webu (/cs/14-kontakt/).
const departments = [
  { dept: 'Zákaznická podpora', person: 'Václav Tůma', tel: '+420 775 387 231', telHref: 'tel:+420775387231', email: 'podpora@prvni-pozice.com' },
  { dept: 'Obchodní oddělení', person: 'Ing. Michal Martínek', tel: '+420 608 717 845', telHref: 'tel:+420608717845', email: 'michal@prvni-pozice.com' },
  { dept: 'Online marketing', person: 'Bc. Antonín Martínek', tel: '+420 776 717 857', telHref: 'tel:+420776717857', email: 'statistiky@prvni-pozice.com' },
  { dept: 'Grafické oddělení', person: 'Nikola Horáková', tel: '', telHref: '', email: 'grafik@prvni-pozice.com' },
  { dept: 'Vedení společnosti', person: 'Mgr. Zdeněk Martínek, MBA', tel: '+420 608 903 395', telHref: 'tel:+420608903395', email: 'zdenek@prvni-pozice.com' },
];
const addresses = [
  { label: 'Sídlo a fakturační adresa', lines: ['První pozice, s.r.o.', 'Na úlehli 1256/9', '141 00 Praha 4 – Michle'] },
  { label: 'Korespondenční adresa', lines: ['První pozice, s.r.o.', 'Skrýšov 78', '393 01 Pelhřimov'] },
  { label: 'Fakturační údaje', lines: ['IČO 29136334', 'DIČ CZ29136334', 'Bankovní účet 2800345268 / 2010'] },
];
---
<Base title="Kontakt — poptávka | První pozice" description="Nezávazná konzultace zdarma. Ozveme se do 24 hodin a řekneme rovnou, kde dává AI smysl.">
  <div class="kont">
    <div class="wrap grid">
      <div class="intro">
        <span class="overline"><span class="dot"></span><span class="label">Nezávazná konzultace</span></span>
        <h1>Řekněte nám, co chcete <u>posunout</u>.</h1>
        <p class="lead">Reagujeme rychle. Jakmile budeme znát váš záměr, přinášíme konkrétní návrhy řešení — a rovnou řekneme, kde vám AI dá náskok a kde byste jen utráceli.</p>

        <div class="bullets">
          <div class="bullet"><span class="chk">✓</span><div><b>Rychlá reakce.</b><p>Ozýváme se rychle a hned se domluvíme na dalším kroku — žádné týdny čekání.</p></div></div>
          <div class="bullet"><span class="chk">✓</span><div><b>Konkrétní návrhy, ne fráze.</b><p>Často se sejdeme osobně a přicházíme s řešením ušitým na míru vašemu záměru.</p></div></div>
          <div class="bullet"><span class="chk">✓</span><div><b>Náskok díky AI.</b><p>Ukážeme, kde vám AI přinese reálný náskok — a kde by byla jen ztrátou času.</p></div></div>
        </div>

        <div class="direct">
          <a class="dcard" href={contact.telHref}><span class="dlabel">Telefon</span><span class="dval">{contact.tel}</span></a>
          <a class="dcard" href={`mailto:${contact.email}`}><span class="dlabel">E-mail</span><span class="dval">{contact.email}</span></a>
        </div>
        <p class="who">{contact.person} · {contact.role}</p>
      </div>

      <div class="panel">
        <h2>Poptávka</h2>
        <form class="form" method="post" action="/api/contact" data-contact-form>
          <p class="hp" aria-hidden="true" style="position:absolute;left:-5000px;top:auto;width:1px;height:1px;overflow:hidden"><label>Toto pole nevyplňujte<input name="poznamka_extra" tabindex="-1" autocomplete="off" /></label></p>
          <div class="field"><label for="name">Jméno</label><input id="name" name="name" required /></div>
          <div class="field"><label for="firma">Firma</label><input id="firma" name="firma" /></div>
          <div class="field"><label for="email">Pracovní e-mail</label><input id="email" name="email" type="email" required /></div>
          <div class="field"><label for="tel">Telefon</label><input id="tel" name="tel" placeholder="+420" /></div>
          <div class="field full"><label>O co máte zájem?</label>
            <div class="chips">
              {interests.map((i) => <label class="chip"><input type="checkbox" name="zajem" value={i} /> {i}</label>)}
            </div>
          </div>
          <div class="field full"><label for="zprava">Stručně k projektu</label><textarea id="zprava" name="zprava" rows="3"></textarea></div>
          <div class="submit">
            <label class="cbrow"><input type="checkbox" name="souhlas" required /> Souhlasím se <a href="/zasady-ochrany-udaju/">zpracováním údajů</a></label>
            <button class="btn primary" type="submit">Odeslat poptávku</button>
          </div>
          <p class="form-status" data-status role="status" aria-live="polite" hidden></p>
        </form>
        <style>
          .form-status { margin-top: 14px; font-size: 15px; font-weight: 500; }
          .form-status.ok { color: #3a7d00; }
          .form-status.err { color: #c62828; }
        </style>
        <script>
          const cf = document.querySelector('[data-contact-form]');
          const t0 = Date.now();
          if (cf) {
            const st = cf.querySelector('[data-status]');
            const btn = cf.querySelector('button[type=submit]');
            cf.addEventListener('submit', async (e) => {
              e.preventDefault();
              const orig = btn.textContent;
              st.hidden = true; btn.disabled = true; btn.textContent = 'Odesílám…';
              try {
                const fd = new FormData(cf), payload = {};
                for (const [k, v] of fd.entries()) {
                  if (k === 'zajem') (payload.zajem ||= []).push(v); else payload[k] = v;
                }
                payload.f_ts = String(Date.now() - t0);
                const r = await fetch('/api/contact', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
                const j = await r.json().catch(() => ({}));
                if (r.ok && j.ok) { cf.reset(); st.textContent = 'Děkujeme, ozveme se co nejdřív.'; st.className = 'form-status ok'; }
                else { st.textContent = j.error || 'Něco se pokazilo, zkuste to prosím znovu.'; st.className = 'form-status err'; }
              } catch {
                st.textContent = 'Odeslání selhalo — zkontrolujte připojení a zkuste to znovu.'; st.className = 'form-status err';
              } finally { st.hidden = false; btn.disabled = false; btn.textContent = orig; }
            });
          }
        </script>
      </div>
    </div>

    <section class="wrap contacts">
      <div class="sec-head2">
        <span class="overline"><span class="dot"></span><span class="label">Všechny kontakty</span></span>
        <h2>Spojte se přímo s oddělením.</h2>
      </div>
      <div class="dept-grid">
        {departments.map((d) => (
          <div class="dept">
            <span class="dept-name">{d.dept}</span>
            <span class="dept-person">{d.person}</span>
            <div class="dept-lines">
              {d.tel && <a href={d.telHref}>{d.tel}</a>}
              <a href={`mailto:${d.email}`}>{d.email}</a>
            </div>
          </div>
        ))}
      </div>
      <div class="addr-grid">
        {addresses.map((a) => (
          <div class="addr">
            <span class="addr-label">{a.label}</span>
            <p>{a.lines.map((l, i) => (<>{i > 0 && <br />}{l}</>))}</p>
          </div>
        ))}
      </div>
      <div class="closing-band">
        <div class="cb-top">
          <span class="cb-kick"><span class="dot"></span>Pojďme na to</span>
          <img class="cb-mark" src="/assets/logo-1p-dark-sm.webp" alt="První pozice" width="320" height="85" />
        </div>
        <p class="cb-head">Od první zprávy<br /><span>k První pozici.</span></p>
      </div>
    </section>
  </div>
</Base>

<style>
  .kont { background: var(--surface-sunken); padding: 64px 0 80px; }
  .grid { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 64px; align-items: start; }
  .intro h1 { font-size: var(--fs-display-lg); font-weight: var(--fw-black); letter-spacing: -.022em; line-height: 1.06; color: var(--text-strong); margin: 16px 0 0; }
  .intro h1 u { text-decoration: none; box-shadow: inset 0 -.12em 0 var(--lime); }
  .lead { font-size: 18px; line-height: var(--lh-body); color: var(--text-muted); margin: 20px 0 0; }
  .bullets { margin: 32px 0 0; display: flex; flex-direction: column; gap: 16px; }
  .bullet { display: flex; gap: 12px; align-items: flex-start; }
  .bullet .chk { width: 26px; height: 26px; border-radius: var(--radius-pill); background: var(--lime-100); color: var(--lime-800); font-weight: 700; font-size: 13px; display: flex; align-items: center; justify-content: center; flex: none; margin-top: 1px; }
  .bullet b { color: var(--text-strong); font-weight: var(--fw-bold); }
  .bullet p { font-size: 15px; color: var(--text-muted); margin: 2px 0 0; }

  .direct { margin-top: 32px; display: flex; gap: 14px; flex-wrap: wrap; }
  .dcard { display: flex; flex-direction: column; gap: 4px; background: #fff; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 16px 20px; flex: 1; min-width: 180px; }
  .dcard:hover { border-color: var(--lime-400); }
  .dlabel { font-family: var(--font-mono); font-size: 12px; letter-spacing: .1em; text-transform: uppercase; color: var(--text-subtle); }
  .dval { font-size: 18px; font-weight: var(--fw-bold); color: var(--text-strong); }
  .who { margin-top: 14px; font-size: 14px; color: var(--text-subtle); }

  .panel { background: #fff; border: 1px solid var(--border); border-radius: var(--radius-2xl); padding: 40px; box-shadow: var(--shadow-md); }
  .panel h2 { font-size: var(--fs-title-md); font-weight: var(--fw-bold); letter-spacing: -.012em; color: var(--text-strong); }
  .form { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-top: 24px; }
  .field { display: flex; flex-direction: column; gap: 7px; }
  .field.full { grid-column: 1 / -1; }
  .field label { font-size: 14px; font-weight: var(--fw-medium); color: var(--text-strong); }
  .field input, .field textarea { padding: 12px 14px; background: #fff; border: 1.5px solid var(--border-strong); border-radius: var(--radius-md); font-family: var(--font-sans); font-size: 16px; color: var(--text); outline: none; resize: none; }
  .field input:focus, .field textarea:focus { border-color: var(--lime); box-shadow: var(--ring); }
  .chips { display: flex; gap: 8px; flex-wrap: wrap; }
  .chip { padding: 8px 14px; font-size: 14px; font-weight: var(--fw-medium); border-radius: var(--radius-pill); background: var(--n-100); color: var(--text); border: 1px solid transparent; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; }
  .chip:has(input:checked) { background: var(--lime-100); color: var(--n-900); border-color: var(--lime-400); }
  .chip input { accent-color: var(--lime); }
  .submit { grid-column: 1 / -1; display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-top: 6px; flex-wrap: wrap; }
  .cbrow { display: flex; align-items: center; gap: 10px; font-size: 14px; color: var(--text-muted); }
  .cbrow input { accent-color: var(--lime); width: 20px; height: 20px; }
  .btn.primary[type="submit"] { padding: 14px 28px; font-size: 16px; }

  /* — Sekce všech kontaktů pod formulářem — */
  .contacts { margin-top: 64px; }
  .sec-head2 { margin-bottom: 28px; }
  .sec-head2 h2 { font-size: var(--fs-display-md); font-weight: var(--fw-black); letter-spacing: -.022em; color: var(--text-strong); margin: 12px 0 0; }
  .dept-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .dept { background: #fff; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 22px; display: flex; flex-direction: column; gap: 5px; }
  .dept-name { font-family: var(--font-mono); font-size: 12px; letter-spacing: .1em; text-transform: uppercase; color: var(--accent-ink); }
  .dept-person { font-size: 17px; font-weight: var(--fw-bold); color: var(--text-strong); }
  .dept-lines { display: flex; flex-direction: column; gap: 2px; margin-top: 6px; }
  .dept-lines a { font-size: 15px; color: var(--text-muted); text-decoration: none; }
  .dept-lines a:hover { color: var(--lime-800); }

  .addr-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 16px; }
  .addr { background: #fff; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 22px; }
  .addr-label { font-family: var(--font-mono); font-size: 12px; letter-spacing: .1em; text-transform: uppercase; color: var(--text-subtle); }
  .addr p { font-size: 15px; line-height: 1.6; color: var(--text); margin: 10px 0 0; }

  /* lime statement blok dle DS (slide-title) — tmavý ink na lime, mono kicker, 1P značka */
  .closing-band { margin-top: 56px; background: var(--lime); border-radius: var(--radius-2xl); padding: 56px 56px 60px; position: relative; overflow: hidden; }
  .closing-band::after { content: ""; position: absolute; right: -120px; top: -120px; width: 420px; height: 420px; border-radius: 999px; background: radial-gradient(circle at 30% 30%, rgba(255,255,255,.35), transparent 62%); pointer-events: none; }
  .cb-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 34px; position: relative; z-index: 1; }
  .cb-kick { font-family: var(--font-mono); font-size: 14px; letter-spacing: .14em; text-transform: uppercase; color: var(--n-900); display: flex; align-items: center; gap: 10px; }
  .cb-kick .dot { width: 10px; height: 10px; border-radius: 999px; background: var(--n-900); }
  .cb-mark { height: 30px; width: auto; display: block; }
  .cb-head { margin: 0; font-size: calc(var(--fs-display-md) + 2px); font-weight: var(--fw-black); letter-spacing: -.022em; line-height: 1.04; color: var(--n-900); position: relative; z-index: 1; }
  .cb-head span { text-decoration: none; box-shadow: inset 0 -.12em 0 #fff; }

  @media (max-width: 980px) {
    .dept-grid, .addr-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 880px) {
    .grid { grid-template-columns: 1fr; gap: 40px; }
    .form { grid-template-columns: 1fr; }
    .intro h1 { font-size: var(--fs-display-md); }
  }
  @media (max-width: 620px) {
    .dept-grid, .addr-grid { grid-template-columns: 1fr; }
  }
</style>
